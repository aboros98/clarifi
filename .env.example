# Required
GOOGLE_API_KEY=your-google-api-key-here

# Database (SQLite for dev, Supabase PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./clarifi.db
# DATABASE_URL=postgresql+asyncpg://postgres:yourpass@db.yourproject.supabase.co:5432/postgres

# LLM models
LLM_MODEL=gemini-2.5-flash-lite
LLM_EXTRACTION_MODEL=gemini-2.5-flash-lite

# Supabase (for Auth + Storage)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=  # From Supabase → Settings → API → JWT Secret

# Frontend (.env.local in frontend/)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_API_URL=http://localhost:8001

# File discovery
WATCH_DIR=./inbox

# Google Drive (optional)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3001/auth/callback

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# memU — long-term semantic memory
MEMU_ENABLED=false
MEMU_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
MEMU_LLM_API_KEY=
MEMU_LLM_MODEL=gemini-2.5-flash-lite

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3001
